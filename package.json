{
  "name": "mantic",
  "private": true,
  "workspaces": [
    "common",
    "backend/api",
    "backend/discord-bot",
    "backend/scheduler",
    "backend/scripts",
    "backend/shared",
    "web",
    "client-common"
  ],
  "scripts": {
    "build:common": "yarn --cwd=common build",
    "build:shared": "yarn --cwd=backend/shared build",
    "build:ci": "yarn build:common && yarn build:shared",
    "typecheck:web": "tsc --pretty --project web/tsconfig.json --noEmit",
    "typecheck:api": "tsc --pretty --project backend/api/tsconfig.json --noEmit --skipLibCheck",
    "typecheck:scheduler": "tsc --pretty --project backend/scheduler/tsconfig.json --noEmit --skipLibCheck",
    "typecheck": "yarn typecheck:web && yarn typecheck:api && yarn typecheck:scheduler",
    "lint:common": "yarn --cwd=common verify:dir",
    "lint:web": "yarn --cwd=web lint",
    "lint:api": "yarn --cwd=backend/api verify:dir",
    "lint:shared": "yarn --cwd=backend/shared verify:dir",
    "lint": "yarn lint:common && yarn lint:api && yarn lint:shared",
    "format:check": "prettier --check web package.json .github",
    "format": "prettier --write web package.json .github",
    "test:common": "yarn --cwd=common test",
    "test:all": "yarn test:common",
    "test": "yarn test:all",
    "verify": "yarn build:ci && yarn typecheck && yarn lint && yarn format:check && yarn test",
    "prepare": "husky",
    "dev:dev": "cross-env GOOGLE_APPLICATION_CREDENTIALS_DEV=./dev-mantic-markets-firebase-adminsdk.json ./dev.sh dev"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "18.18.8",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "concurrently": "8.2.2",
    "eslint": "8.57.0",
    "eslint-plugin-lodash": "^7.4.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "nodemon": "2.0.20",
    "prettier": "2.8.4",
    "ts-node": "10.9.1",
    "tsc-alias": "1.8.2",
    "tsconfig-paths": "4.1.2",
    "typescript": "5.5.4"
  }
}
